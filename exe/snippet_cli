#!/usr/bin/env ruby
# frozen_string_literal: true

$LOAD_PATH.unshift(File.join(__dir__, '..', 'lib'))

# gum confirm
ENV['GUM_CONFIRM_PROMPT_FOREGROUND'] = '231'
ENV['GUM_CONFIRM_SELECTED_FOREGROUND'] = '#F2D07C'
ENV['GUM_CONFIRM_SELECTED_BACKGROUND'] = '#6B7A90'

# gum choose — replaces default purple cursor (used for trigger type)
ENV['GUM_CHOOSE_CURSOR_FOREGROUND'] = '#8CAAED'
ENV['GUM_CHOOSE_SELECTED_FOREGROUND'] = '#A5D18A'
ENV['GUM_CHOOSE_HEADER_FOREGROUND'] = '231'

# gum filter — replaces default purple indicator and pink match highlight
ENV['GUM_FILTER_INDICATOR_FOREGROUND'] = '#8CAAED'
ENV['GUM_FILTER_MATCH_FOREGROUND'] = '#E88284'
ENV['GUM_FILTER_SELECTED_FOREGROUND'] = '#A5D18A'
ENV['GUM_FILTER_PROMPT_FOREGROUND'] = '#8CAAED'
ENV['GUM_FILTER_HEADER_FOREGROUND'] = '231'

# gum input — replaces default purple cursor
ENV['GUM_INPUT_CURSOR_FOREGROUND'] = '#8CAAED'
ENV['GUM_INPUT_PROMPT_FOREGROUND'] = '#8CAAED'
ENV['GUM_INPUT_HEADER_FOREGROUND'] = '231'

# gum write — replaces default purple cursor
ENV['GUM_WRITE_CURSOR_FOREGROUND'] = '#8CAAED'
ENV['GUM_WRITE_PROMPT_FOREGROUND'] = '#8CAAED'
ENV['GUM_WRITE_HEADER_FOREGROUND'] = '231'

begin
  require 'snippet_cli'
  require 'snippet_cli/banner'

  if $stdout.tty?
    puts SnippetCli.banner
    puts
  end

  Dry::CLI.new(SnippetCli::CLI).call
rescue Interrupt
  if defined?(SnippetCli::UI)
    puts
    SnippetCli::UI.error('Interrupted, exiting snippet_cli.')
  else
    warn "\nInterrupted."
  end
  exit 130
end
